<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#060A14"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp"
        android:gravity="center">

        <LinearLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/card_background"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="52dp">

            <ImageView
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:src="@android:drawable/ic_lock_lock"
                app:tint="#00E5FF"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LockTalk"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#00E5FF"
            android:letterSpacing="0.08"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Encrypted. Secure. Yours."
            android:textSize="13sp"
            android:textColor="#5A7A9A"
            android:letterSpacing="0.05"
            android:layout_marginBottom="52dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="EMAIL"
            android:textSize="10sp"
            android:textColor="#00E5FF"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Enter your email"
            android:inputType="textEmailAddress"
            android:textColor="#E2EEFF"
            android:textColorHint="#2A4060"
            android:background="@drawable/input_background"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textSize="15sp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PASSWORD"
            android:textSize="10sp"
            android:textColor="#00E5FF"
            android:letterSpacing="0.12"
            android:layout_marginBottom="6dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Enter your password"
            android:inputType="textPassword"
            android:textColor="#E2EEFF"
            android:textColorHint="#2A4060"
            android:background="@drawable/input_background"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textSize="15sp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot password?"
            android:textColor="#5A7A9A"
            android:textSize="13sp"
            android:layout_gravity="end"
            android:layout_marginBottom="32dp"/>

        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="SIGN IN"
            android:textColor="#060A14"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:backgroundTint="#00E5FF"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <View
                android:layout_width="0dp"
                android:layout_height="0.5dp"
                android:layout_weight="1"
                android:background="#1E3050"
                android:layout_marginEnd="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="or"
                android:textColor="#2A4A6A"
                android:textSize="13sp"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0.5dp"
                android:layout_weight="1"
                android:background="#1E3050"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvRegister"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don't have an account? Create one"
            android:textColor="#00E5FF"
            android:textSize="14sp"
            android:layout_marginBottom="40dp"/>

    </LinearLayout>

</ScrollView>