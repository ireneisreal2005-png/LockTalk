<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060A14"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="68dp"
        android:background="#0B1120"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="16dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#00E5FF"/>

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="12dp">

            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivReceiverPhoto"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/default_avatar"/>

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvReceiverName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#E2EEFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.02"/>

            <TextView
                android:id="@+id/tvOnlineStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="online"
                android:textColor="#00E5FF"
                android:textSize="11sp"
                android:letterSpacing="0.03"/>

        </LinearLayout>

        <ImageButton
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_more"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#5A7A9A"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#0D1E38"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:clipToPadding="false"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:gravity="center_vertical"
        android:background="#0B1120">

        <ImageButton
            android:id="@+id/btnImage"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_gallery"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#00E5FF"/>

        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:hint="Message..."
            android:textColor="#E2EEFF"
            android:textColorHint="#2A4060"
            android:background="@drawable/input_background"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="10dp"
            android:textSize="15sp"/>

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/circle_send_button"
            app:tint="#060A14"/>

    </LinearLayout>

</LinearLayout>