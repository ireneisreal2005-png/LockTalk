<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:gravity="center_vertical"
    android:background="@drawable/user_item_bg">

    <FrameLayout
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:layout_marginEnd="14dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/ivProfile"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@drawable/default_avatar"/>

        <View
            android:id="@+id/onlineDot"
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:background="@drawable/online_dot"
            android:layout_gravity="bottom|end"
            android:visibility="invisible"/>

    </FrameLayout>
    <ImageView
        android:id="@+id/pinIcon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_pin"
        android:visibility="gone"
        android:layout_marginEnd="4dp"/>

    <ImageView
        android:id="@+id/muteIcon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_mute"
        android:visibility="gone"
        android:layout_marginEnd="4dp"/>

    <ImageView
        android:id="@+id/banIcon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_ban"
        android:visibility="gone"
        android:layout_marginEnd="4dp"/>

    <ImageView
        android:id="@+id/blockIcon"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:src="@drawable/ic_block"
        android:tint="#FF3B30"
        android:visibility="gone"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#E2EEFF"
                android:letterSpacing="0.01"/>

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#2A4A6A"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="3dp">

            <TextView
                android:id="@+id/tvLastMessage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="13sp"
                android:textColor="#5A7A9A"
                android:maxLines="1"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/tvUnreadCount"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:gravity="center"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#060A14"
                android:background="@drawable/unread_badge"
                android:visibility="gone"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>